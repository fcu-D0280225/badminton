MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=app_user
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=badminton

# CORS：除了預設 localhost dev port + 區網 IP 外，可額外允許其他來源（逗號分隔）
# 例：CORS_ORIGINS=https://badminton.example.com,https://admin.example.com
CORS_ORIGINS=

# TypeORM schema 同步：預設 OFF（防 production 啟動自動 DROP 欄位）
# 只在開發環境且自願承擔風險時設為 true；schema 改動請走 migration 流程
# TYPEORM_SYNC=true
#
# 啟動時自動 apply pending migrations：預設 ON
# 若需手動控制 migration 時機（例如先 migration:show 檢視）可設 false
# TYPEORM_MIGRATIONS_RUN=false
